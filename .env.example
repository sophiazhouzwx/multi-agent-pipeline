# Required: Anthropic API access (CVS Health proxy or direct).
# PydanticAI's AnthropicModel reads both of these automatically.
ANTHROPIC_API_KEY=sk-...
ANTHROPIC_BASE_URL=https://your-proxy.example.com   # optional; leave unset for api.anthropic.com

# Optional: drop-in providers for any role in src/config.py.
# Set these and change one constant in config.py to swap a Claude tier
# for GPT-4o or Gemini without touching agent code.
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...

# Optional: enable Logfire tracing (free tier).
# LOGFIRE_TOKEN=...
